#!/bin/bash
# Create libfluidsynth.so.2 symlink -> real .so.3 library from fluidsynth-headless
set -e
LIBDIR=/usr/lib/aarch64-linux-gnu
REAL_LIB=$(readlink -f "${LIBDIR}/libfluidsynth.so.3" 2>/dev/null || true)
if [ -z "${REAL_LIB}" ]; then
    echo "ERROR: libfluidsynth.so.3 not found; fluidsynth-headless must be installed first" >&2
    exit 1
fi
REAL_NAME=$(basename "${REAL_LIB}")
ln -sf "${REAL_NAME}" "${LIBDIR}/libfluidsynth.so.2"

#DEBHELPER#