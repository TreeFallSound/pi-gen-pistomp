Build-Depends: debhelper-compat (= 13), nasm,
 libx264-dev, libx265-dev, libvpx-dev, libopus-dev, libvorbis-dev,
 libmp3lame-dev, libtheora-dev, libass-dev, libfreetype6-dev,
 libfontconfig1-dev, libfribidi-dev, libharfbuzz-dev,
 libgnutls28-dev, zlib1g-dev, libbz2-dev
Standards-Version: 4.6.2

Package: ffmpeg-pistomp
Architecture: arm64
Depends: ${shlibs:Depends}, ${misc:Depends}
Provides: ffmpeg
Conflicts: ffmpeg
Replaces: ffmpeg
Description: Minimal ffmpeg build for pi-Stomp
 A stripped-down ffmpeg build intended for pi-Stomp's ps-record-lcd
 utility. Supports rawvideo input and common codecs (H.264, VP8/9,
 Opus, MP3, Vorbis) without any SDL2, X11, OpenGL, PulseAudio, or
 other display/audio-output device dependencies.
