#!/usr/bin/make -f
export DH_VERBOSE=1

PKG=ffmpeg-pistomp

%:
	dh $@

override_dh_auto_configure:
	./configure \
		--prefix=/usr \
		--libdir=/usr/lib/aarch64-linux-gnu \
		--shlibdir=/usr/lib/aarch64-linux-gnu \
		--incdir=/usr/include/aarch64-linux-gnu \
		--enable-gpl \
		--enable-version3 \
		--disable-static \
		--enable-shared \
		--enable-pic \
		--disable-debug \
		--disable-doc \
		--disable-htmlpages \
		--disable-manpages \
		--disable-podpages \
		--disable-txtpages \
		--disable-ffplay \
		--disable-ffprobe \
		--disable-avdevice \
		--disable-avfilter \
		--disable-postproc \
		--disable-swresample \
		--disable-network \
		--disable-bzlib \
		--disable-libopenjpeg \
		--disable-iconv \
		--disable-zlib \
		--disable-sdl2 \
		--disable-xlib \
		--disable-libxcb \
		--disable-libxcb-shm \
		--disable-libxcb-xfixes \
		--disable-libxcb-shape \
		--disable-libpulse \
		--disable-alsa \
		--disable-libopus \
		--disable-libvorbis \
		--disable-libmp3lame \
		--disable-libtheora \
		--disable-libass \
		--disable-libfreetype \
		--disable-libfontconfig \
		--disable-libfribidi \
		--disable-libharfbuzz \
		--disable-gnutls \
		--disable-openssl \
		--disable-libx264 \
		--disable-libx265 \
		--disable-libvpx \
		--enable-libx264 \
		--enable-encoder=libx264 \
		--enable-muxer=mp4 \
		--enable-demuxer=rawvideo \
		--enable-parser=h264 \
		--enable-protocol=file,pipe \
		--enable-filter=scale,format \
		--enable-avcodec \
		--enable-avformat \
		--enable-swscale \
		--enable-avutil

override_dh_auto_build:
	$(MAKE) -j$$(nproc)

override_dh_auto_install:
	$(MAKE) DESTDIR="$(CURDIR)/debian/$(PKG)" install
	# Remove development files we don't need in the runtime image.
	rm -rf "$(CURDIR)/debian/$(PKG)/usr/include"
	rm -f "$(CURDIR)/debian/$(PKG)/usr/lib/aarch64-linux-gnu"/*.a
	rm -f "$(CURDIR)/debian/$(PKG)/usr/lib/aarch64-linux-gnu"/pkgconfig/*.pc
	rm -f "$(CURDIR)/debian/$(PKG)/usr/lib/aarch64-linux-gnu"/*.so

override_dh_auto_test:
	# No upstream test suite run needed; configure-time probes are enough.
	true
