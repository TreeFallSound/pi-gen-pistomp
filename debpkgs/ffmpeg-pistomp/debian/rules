#!/usr/bin/make -f
export DH_VERBOSE=1

PKG=ffmpeg-pistomp

%:
	dh $@

override_dh_auto_clean:
	# Upstream distclean fails before configure; ignore it.
	true

override_dh_auto_configure:
	./configure \
		--prefix=/usr \
		--extra-version="pistomp" \
		--toolchain=hardened \
		--disable-stripping \
		--enable-gpl \
		--enable-version3 \
		--disable-static \
		--enable-shared \
		--enable-pic \
		--disable-debug \
		--disable-doc \
		--disable-htmlpages \
		--disable-manpages \
		--disable-podpages \
		--disable-txtpages \
		--disable-autodetect \
		--disable-everything \
		--disable-network \
		--disable-protocols \
		--enable-protocol=file \
		--enable-protocol=pipe \
		--disable-indevs \
		--disable-outdevs \
		--disable-alsa \
		--disable-sdl2 \
		--disable-xlib \
		--disable-libxcb \
		--disable-libxcb-shm \
		--disable-libxcb-shape \
		--disable-libxcb-xfixes \
		--disable-libpulse \
		--disable-opengl \
		--disable-openal \
		--disable-libjack \
		--disable-libplacebo \
		--disable-vaapi \
		--disable-vdpau \
		--disable-vulkan \
		--disable-libdrm \
		--disable-hwaccels \
		--enable-v4l2-m2m \
		--enable-encoder=h264_v4l2m2m \
		--enable-decoder=h264_v4l2m2m \
		--enable-encoder=hevc_v4l2m2m \
		--enable-decoder=hevc_v4l2m2m \
		--enable-encoder=rawvideo \
		--enable-encoder=libx264 \
		--enable-encoder=libx264rgb \
		--enable-decoder=rawvideo \
		--enable-decoder=h264 \
		--enable-decoder=hevc \
		--enable-decoder=vp8 \
		--enable-decoder=vp9 \
		--enable-decoder=mjpeg \
		--enable-decoder=png \
		--enable-decoder=mpeg4 \
		--enable-decoder=aac \
		--enable-decoder=mp3float \
		--enable-decoder=flac \
		--enable-decoder=libvorbis \
		--enable-muxer=rawvideo \
		--enable-muxer=mov \
		--enable-muxer=mp4 \
		--enable-muxer=matroska \
		--enable-muxer=webm \
		--enable-muxer=avi \
		--enable-muxer=flv \
		--enable-muxer=ogg \
		--enable-demuxer=rawvideo \
		--enable-demuxer=mov \
		--enable-demuxer=mp4 \
		--enable-demuxer=matroska \
		--enable-demuxer=webm \
		--enable-demuxer=avi \
		--enable-demuxer=flv \
		--enable-demuxer=ogg \
		--enable-demuxer=wav \
		--enable-demuxer=flac \
		--enable-demuxer=mp3 \
		--enable-filter=scale \
		--enable-filter=format \
		--enable-filter=fps \
		--enable-filter=null \
		--enable-filter=crop \
		--enable-filter=buffer \
		--enable-filter=buffersink \
		--enable-libx264 \
		--enable-libvorbis \
		--enable-ffmpeg \
		--disable-ffplay \
		--disable-ffprobe

override_dh_auto_build:
	$(MAKE) -j$$(nproc)

override_dh_auto_install:
	$(MAKE) DESTDIR="$(CURDIR)/debian/$(PKG)" install
	# Remove development files we don't need in the runtime image.
	rm -rf "$(CURDIR)/debian/$(PKG)/usr/include"
	rm -f "$(CURDIR)/debian/$(PKG)/usr/lib/aarch64-linux-gnu"/*.a
	rm -f "$(CURDIR)/debian/$(PKG)/usr/lib/aarch64-linux-gnu"/pkgconfig/*.pc
	rm -f "$(CURDIR)/debian/$(PKG)/usr/lib/aarch64-linux-gnu"/*.so

override_dh_auto_test:
	# No upstream test suite run needed; configure-time probes are enough.
	true
