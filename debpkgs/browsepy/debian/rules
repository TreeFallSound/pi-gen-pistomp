#!/usr/bin/make -f
export DH_VERBOSE=1

PKG=browsepy
BROWSEPY_SRC_DIR=$(CURDIR)/../browsepy-src
VENV_DIR=$(CURDIR)/debian/$(PKG)/opt/pistomp/venvs/browsepy

%:
	dh $@

override_dh_auto_configure:
	if [ ! -d "$(BROWSEPY_SRC_DIR)" ]; then \
		git clone --branch "$(BROWSEPY_REF)" --depth 1 \
			"$(BROWSEPY_REPO)" \
			"$(BROWSEPY_SRC_DIR)"; \
	fi

override_dh_auto_build:
	# Nothing to build — browsepy is pure Python, installed into venv below.

override_dh_auto_install:
	# Create a relocatable venv and install browsepy
	python3 -m venv --copies --system-site-packages "$(VENV_DIR)"
	"$(VENV_DIR)/bin/pip" install --no-deps "$(BROWSEPY_SRC_DIR)"
	# Install systemd service file
	install -Dm 644 debian/browsepy.browsepy.service \
		$(CURDIR)/debian/browsepy/lib/systemd/system/browsepy.service

override_dh_auto_test:
	# Upstream 'make test' runs lint tools (pep8, flake8, eslint) not present
	# in the build environment. Skip linting; package installation is verified.
	:

override_dh_installsystemd:
	# Service enablement is handled by stage2/05-pistomp/01-run.sh ln -sf,
	# not by deb-systemd-helper. The unit file is installed manually above.
