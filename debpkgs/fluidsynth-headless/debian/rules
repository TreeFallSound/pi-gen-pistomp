#!/usr/bin/make -f
%:
	dh $@ --buildsystem=cmake

override_dh_auto_test:
	$(MAKE) -C obj-aarch64-linux-gnu check

override_dh_auto_configure:
	dh_auto_configure -- \
		-Denable-sdl3=OFF \
		-Denable-jack=ON \
		-Denable-alsa=ON \
		-Denable-pulseaudio=OFF \
		-Denable-libsndfile=ON \
		-Denable-dbus=ON \
		-Denable-ladspa=ON \
		-Denable-portaudio=OFF \
		-Denable-readline=ON \
		-DLIB_SUFFIX=""
