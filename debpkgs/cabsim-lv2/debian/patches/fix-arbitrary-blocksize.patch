+    /* Normalize (FFTW IFFT is unscaled) and output with generalized overlap-add.
+     * Works for any block size: out[j] = outbuf[j]/SIZE + accumulated overlap,
+     * then shift the overlap window forward by n_samples. */
+    for (j = 0; j < (uint32_t)SIZE; j++)
+        outbuf[j] /= (float)SIZE;
 
+    for (j = 0; j < n_samples; j++)
+        out[j] = outbuf[j] + overlap[j];
+
+    for (j = 0; j < (uint32_t)(SIZE - (int)n_samples); j++) {
+        uint32_t src = j + n_samples;
+        overlap[j] = outbuf[src];
+        if (src < (uint32_t)(SIZE - (int)n_samples))
+            overlap[j] += overlap[src];
+    }
