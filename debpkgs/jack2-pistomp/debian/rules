#!/usr/bin/make -f
export DH_VERBOSE=1

%:
	dh $@ --with quilt

override_dh_auto_configure:
	# Use bundled waf with patched waflib (imp → types for Python 3.12+)
	#
	# --clients / --ports-per-application size JackConnectionManager, which the
	# graph double-buffers into the shm segment. Upstream's 256/2048 defaults cost
	# a 36MB fixed base before a single port exists; 64/512 brings that to 8MB.
	# A loaded pedalboard uses ~15 clients and ~42 ports. See jackdrc for --port-max.
	CXXFLAGS="$(CXXFLAGS) -I/usr/include/db5.3" \
	LDFLAGS="$(LDFLAGS) -ldb-5.3" \
	./waf configure \
		--prefix=/usr \
		--libdir=/usr/lib/aarch64-linux-gnu \
		--autostart=none \
		--systemd-unit \
		--classic \
		--clients=64 \
		--ports-per-application=512 \
		--dbus

override_dh_auto_build:
	./waf build

override_dh_auto_install:
	./waf --destdir=$(CURDIR)/debian/jack2-pistomp install
