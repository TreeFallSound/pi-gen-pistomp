#!/usr/bin/make -f
export DH_VERBOSE=1

PKG=pi-stomp
PISTOMP_SRC_DIR=$(CURDIR)/../pi-stomp-src
VENV_DIR=$(CURDIR)/debian/$(PKG)/opt/pistomp/venvs/pi-stomp
SRC_INSTALL_DIR=$(CURDIR)/debian/$(PKG)/opt/pistomp/pi-stomp

%:
	dh $@

override_dh_auto_clean:
	# pi-stomp has pyproject.toml which can trigger python-distutils
	# detection in compat 12+. We don't need to clean anything.
	true

override_dh_auto_test:
	# No tests to run in the build environment.
	true

override_dh_auto_configure:
	# Clone pi-stomp source if not already present (build.sh normally does
	# this; this is a fallback for direct dpkg-buildpackage invocations).
	if [ ! -d "$(PISTOMP_SRC_DIR)" ]; then \
		git clone --branch "$(PISTOMP_BRANCH)" --depth 1 \
			"$(PISTOMP_REPO)" \
			"$(PISTOMP_SRC_DIR)"; \
		mkdir -p "$(PISTOMP_SRC_DIR)/.git-meta"; \
		printf '%s\n' "$(PISTOMP_REPO)" > "$(PISTOMP_SRC_DIR)/.git-meta/origin-url"; \
		printf '%s\n' "$(PISTOMP_BRANCH)" > "$(PISTOMP_SRC_DIR)/.git-meta/branch"; \
		git -C "$(PISTOMP_SRC_DIR)" rev-parse HEAD > "$(PISTOMP_SRC_DIR)/.git-meta/built-sha"; \
	fi

override_dh_auto_build:
	true

override_dh_auto_install:
	# Install source tree (including .git-meta/ dotdir for on-device git init)
	mkdir -p "$(SRC_INSTALL_DIR)"
	cp -a "$(PISTOMP_SRC_DIR)/." "$(SRC_INSTALL_DIR)/"
	# Remove git metadata and test snapshots to keep the package clean
	rm -rf "$(SRC_INSTALL_DIR)"/.git
	rm -rf "$(SRC_INSTALL_DIR)"/tests
	# Build venv here (not in dh_auto_build) so dh_prep doesn't wipe it before packaging
	uv venv --python /usr/bin/python3 --system-site-packages "$(VENV_DIR)"
	UV_PROJECT_ENVIRONMENT="$(VENV_DIR)" \
		uv sync --frozen --no-dev --no-editable --extra hardware \
		--project "$(PISTOMP_SRC_DIR)"
	# Install systemd service file
	install -Dm 644 debian/pi-stomp.mod-ala-pi-stomp.service \
		$(CURDIR)/debian/pi-stomp/lib/systemd/system/mod-ala-pi-stomp.service

override_dh_dwz:
	# Skip DWARF compression — PyPI wheel .so files don't have valid DWARF

override_dh_shlibdeps:
	# Skip — all .so dependencies are private libs bundled inside PyPI wheels

override_dh_installsystemd:
	# Service enablement is handled by stage2/05-pistomp/01-run.sh ln -sf,
	# not by deb-systemd-helper. The unit file is installed manually above.
