#!/bin/sh
set -e
# Remove any lv2plugins.tar.gz copy so the deb version takes precedence.
# mod-host scans ~/.lv2 before /usr/lib/lv2, so a user-dir copy would shadow
# this package if left in place.
if [ -d /home/pistomp/.lv2/loopjefe.lv2 ]; then
    rm -rf /home/pistomp/.lv2/loopjefe.lv2
fi
if [ -d /home/pistomp/.lv2/loopjefe-2x2.lv2 ]; then
    rm -rf /home/pistomp/.lv2/loopjefe-2x2.lv2
fi
#DEBHELPER#
