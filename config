# pi-gen build-time settings only.
# User-facing configuration (WiFi, hostname, password, timezone, JACK) lives in
# stage2/05-pistomp/files/pistomp.conf, which firstboot.sh applies on first boot.

IMG_NAME='pistompOS'
RELEASE=trixie
DEPLOY_COMPRESSION="none"

LOCALE_DEFAULT="en_US.UTF-8"
KEYBOARD_KEYMAP=us

FIRST_USER_NAME="pistomp"

# Account is locked until firstboot.sh sets the password from pistomp.conf.
# FIRST_USER_PASS is intentionally unset here.
DISABLE_FIRST_BOOT_USER_RENAME=1
ENABLE_SSH=1
ENABLE_CLOUD_INIT=0
