[Unit]
Description=Boot log to SD card
DefaultDependencies=no
After=local-fs.target
Before=jack.service mod-host.service mod-ui.service firstboot.service

[Service]
Type=simple
ExecStart=/bin/sh -c 'exec journalctl -b -f -o short-monotonic >> /boot/firmware/boot.log'
Restart=no

[Install]
WantedBy=multi-user.target
