#!/bin/sh
# JACK startup script. Parameters are read from /etc/default/jack, which is
# written by firstboot.sh from /boot/pistomp.conf. If firstboot hasn't run
# yet, this exits with an error and systemd's Restart=always will retry.
set -e

if [ ! -f /etc/default/jack ]; then
    echo "ERROR: /etc/default/jack not found — firstboot.sh has not run yet" >&2
    exit 1
fi

. /etc/default/jack

if [ -z "${JACK_SAMPLE_RATE}" ] || [ -z "${JACK_PERIOD}" ]; then
    echo "ERROR: JACK_SAMPLE_RATE or JACK_PERIOD not set in /etc/default/jack" >&2
    exit 2
fi

# JACK preallocates an 8192-frame buffer per port regardless of JACK_PERIOD, so the
# shm segment costs ~33KB/port on top of a ~36MB fixed base. The 2048-port default
# means 102MB resident — 22% of RAM on a 512MB Pi 3A+. A loaded pedalboard uses ~42.
JACK_PORT_MAX="${JACK_PORT_MAX:-256}"

exec env JACK_DRIVER_DIR=/usr/lib/aarch64-linux-gnu/jack /usr/bin/jackd -t 2000 -R -P 75 --port-max "${JACK_PORT_MAX}" -d alsa -d hw:0 -r "${JACK_SAMPLE_RATE}" -p "${JACK_PERIOD}" -n 2 -X seq -s
