#!/bin/bash
# Lightweight USB auto-mount for headless pi-Stomp systems.
# Triggered by udev add/remove events for USB mass-storage partitions.
set -euo pipefail

ACTION="${1:-}"
DEV="${2:-}"
MOUNT_BASE="/media"

if [[ -z "${ACTION}" || -z "${DEV}" ]]; then
    echo "Usage: $0 {add|remove} <kernel-device>" >&2
    exit 1
fi

# Only handle real partitions with a filesystem.
ID_FS_TYPE=$(/sbin/blkid -s TYPE -o value "/dev/${DEV}" 2>/dev/null || true)
if [[ -z "${ID_FS_TYPE}" ]]; then
    exit 0
fi

# Use filesystem label as mountpoint name; fall back to device name.
LABEL=$(/sbin/blkid -s LABEL -o value "/dev/${DEV}" 2>/dev/null || true)
MOUNT_NAME="${LABEL:-${DEV}}"
MOUNT_POINT="${MOUNT_BASE}/${MOUNT_NAME}"

case "${ACTION}" in
    add)
        mkdir -p "${MOUNT_POINT}"
        # Mount with permissive permissions so the pistomp user can read/write.
        if mount -o "rw,nodev,nosuid,uid=1000,gid=1000,umask=000" "/dev/${DEV}" "${MOUNT_POINT}" 2>/dev/null; then
            logger -t pistomp-usb-mount "Mounted /dev/${DEV} at ${MOUNT_POINT}"
        else
            rmdir "${MOUNT_POINT}" 2>/dev/null || true
        fi
        ;;
    remove)
        if mountpoint -q "${MOUNT_POINT}" 2>/dev/null; then
            umount "${MOUNT_POINT}" 2>/dev/null || umount -l "${MOUNT_POINT}" 2>/dev/null || true
            logger -t pistomp-usb-mount "Unmounted ${MOUNT_POINT}"
        fi
        rmdir "${MOUNT_POINT}" 2>/dev/null || true
        ;;
    *)
        echo "Unknown action: ${ACTION}" >&2
        exit 1
        ;;
esac
