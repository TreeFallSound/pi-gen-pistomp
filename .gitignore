deploy/*
work/*
postrun.sh
SKIP
SKIP_IMAGES
.pc
*-pc

# Built .deb cache (populated by debpkgs/*/build.sh and build-rt-kernel-docker.sh)
cache/

# Local .deb overrides (populated by build-package-docker.sh) — installed by
# the next image build in preference to the published apt repo
overrides/

# Binary-only .deb staging trees (created by build.sh, not source)
# Matches debpkgs/<pkg>/debian/<pkg>/ — the staging subdir named after the package
debpkgs/*/debian/*/usr/
debpkgs/*/debian/*/DEBIAN/

# Generated by gen-font-h.py during build
debpkgs/lcd-splash/src/font.h

__pycache__/
*.pyc

.vscode/settings.json
